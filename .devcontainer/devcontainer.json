{
  "name": "Py-Scaffold Dev Container",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "api",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "extensions": [
    "ms-python.python",
    "ms-azuretools.vscode-docker",
    "ms-python.vscode-pylance"
  ],
  "postCreateCommand": "uv sync",
  "remoteUser": "root"
}